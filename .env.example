# Transmission RPC connection
# Default: http://localhost:9091/transmission/rpc
TRANSMISSION_URL=http://localhost:9091/transmission/rpc

# Transmission RPC credentials (required)
TRANSMISSION_USER=admin
TRANSMISSION_PASS=secret

# HTTP server listen address
# Default: :8080 (all interfaces, port 8080)
LISTEN_ADDR=:8080

# CORS origin for frontend requests (no wildcard allowed)
# Default: http://localhost:8080
# Set to your frontend URL in production (e.g., https://example.com)
CORS_ORIGIN=http://localhost:8080

# Enable/disable Web UI
# Default: true
WEBUI_ENABLED=true

# Enable/disable Telegram bot
# Default: false
# Requires TELEGRAM_TOKEN to be set when enabled
TELEGRAM_BOT_ENABLED=false

# Telegram bot token (required if TELEGRAM_BOT_ENABLED=true)
# Get token from BotFather: https://t.me/botfather
TELEGRAM_TOKEN=

# Telegram usernames allowed to use the bot (comma-separated, @ prefix optional)
# Required only if TELEGRAM_BOT_ENABLED=true
# Example: johndoe,@janedoe
TELEGRAM_USERS=

# Logging level: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Auto file priority: first N files get high priority,
# remaining files get low priority
FILE_PRIORITY_ENABLED=false
FILE_PRIORITY_HIGH_COUNT=3
